@inject GameLogic gameInfo
@inject IConfiguration config
@inject IJSRuntime JS

<EditForm Model="@NewGame" OnValidSubmit="@HandleValidSubmit" class="start-game-form">
    <div class="start-game-header">
        <h3>New Game</h3>
        <p class="start-game-subtitle">Set the board size and launch when ready.</p>
    </div>

    <div class="start-game-section">
        <div class="start-game-grid">
            <label class="start-game-field">
                Rows
                <InputNumber DisplayName="Rows" @bind-Value="NewGame.NumRows" class="form-control start-game-input" />
            </label>
            <label class="start-game-field">
                Columns
                <InputNumber DisplayName="Columns" @bind-Value="NewGame.NumColumns" class="form-control start-game-input" />
            </label>
            <div class="start-game-toggle">
                <InputCheckbox id="useCustomEmoji" @bind-Value="NewGame.UseCustomEmoji" class="form-check-input" />
                <label class="form-label" for="useCustomEmoji">Use custom emoji</label>
            </div>
        </div>

        @if (NewGame.UseCustomEmoji)
        {
            <label class="start-game-field start-game-field--emoji">
                Cell Icon
                <InputText DisplayName="Cell Icon" @bind-Value="NewGame.CellIcon" maxlength="2" class="form-control start-game-input start-game-emoji" />
            </label>
        }
    </div>

    <div class="start-game-section start-game-section--inline">
        <div class="start-game-toggle">
            <InputCheckbox id="isTimed" DisplayName="Is Timed" @bind-Value="NewGame.IsTimed" class="form-check-input" />
            <label class="form-label" for="isTimed">Timed Game</label>
        </div>
        @if (NewGame.IsTimed)
        {
            <label class="start-game-field">
                Minutes
                <input type="number" class="form-control start-game-input" min="1" max="10" @bind="NewGame.TimeLimitInMinutes" />
            </label>
        }
    </div>

    <div class="start-game-section start-game-actions">
        @if (!SharedState.IsAdmin)
        {
            <label class="start-game-field">
                Password
                <InputText type="password" DisplayName="Password" @bind-Value="NewGame.SecretCode" class="form-control start-game-input" />
            </label>
        }
        <button class="btn btn-primary start-game-submit" type="submit">Launch Game</button>

        @if (startGameError != null)
        {
            <div class="error-message start-game-error">
                <strong>Access Denied</strong> &mdash; Invalid password
            </div>
        }
    </div>
</EditForm>

@code
{
    private NewGameInfo NewGame = new();
    private string? startGameError;

    [CascadingParameter]
    public SharedStateClass SharedState { get; set; } = default!;

    protected override void OnInitialized()
    {
        if (gameInfo.LastGameInfo is { } last)
        {
            NewGame.NumRows = last.NumRows;
            NewGame.NumColumns = last.NumColumns;
            NewGame.CellIcon = last.CellIcon;
            NewGame.IsTimed = last.IsTimed;
            NewGame.TimeLimitInMinutes = last.TimeLimitInMinutes;
        }
        else
        {
            NewGame.NumRows = config.GetValue<int>("BOARD_HEIGHT", 20);
            NewGame.NumColumns = config.GetValue<int>("BOARD_WIDTH", 30);
        }
    }

    private async Task HandleValidSubmit()
    {
        if (SharedState.IsAdmin)
        {
            NewGame.SecretCode = SharedState.AdminPassword ?? string.Empty;
        }
        else if (NewGame.SecretCode != config["SECRET_CODE"])
        {
            startGameError = "Invalid password.  Unable to start game.";
            return;
        }
        else
        {
            // Password was typed and is correct — elevate to admin and remember it
            SharedState.IsAdmin = true;
            SharedState.AdminPassword = NewGame.SecretCode;
            await JS.InvokeVoidAsync("localStorage.setItem", "adminPassword", NewGame.SecretCode);
        }
        startGameError = null;
        SharedState.CellIcon = NewGame.CellIcon;
        SharedState.UseCustomEmoji = NewGame.UseCustomEmoji;
        gameInfo.StartGame(NewGame);
        SharedState.GameEndsOn = NewGame.TimeLimitInMinutes.HasValue ? DateTime.Now.AddMinutes(NewGame.TimeLimitInMinutes.Value) : null;
    }
}
